# =============================================================================
# Experiment-level configuration: {{ name }}
# Generated from: {{ _config_file }}
#
# This file controls HIGH-LEVEL experiment behaviour read by scripts/setup.py
# at runtime.  OceanTracker per-scenario configs live in params/base/ and
# params/prod/.
# =============================================================================

# ---------------------------------------------------------------------------
# User / cluster settings
# ---------------------------------------------------------------------------
user:
  email: "{{ user.email | default('user@institution.edu') }}"
  conda_path: "{{ user.conda_path | default('/path/to/miniconda3/etc/profile.d/conda.sh') }}"
  env: "{{ user.env | default('oceantracker') }}"
  viz_env: "{{ user.viz_env | default('oceantracker_viz') }}"
  output_dir: "{{ user.output_dir | default('/scratch/ptm/') }}"

# ---------------------------------------------------------------------------
# Data and output paths (relative to experiment root)
# ---------------------------------------------------------------------------
paths:
  polygons_dir: "{{ paths.polygons_dir | default('../data/polygons') }}"
  oceantracker_base_dir: "{{ paths.oceantracker_base_dir | default('../params/base') }}"
  tile_cache_dir: "{{ paths.tile_cache_dir | default('../outputs/animations/tiles_cache') }}"
  hindcasts_source_dir: "{{ paths.hindcasts_source_dir | default('/path/to/hindcasts/') }}"
  hindcasts_symlink_dir: "{{ paths.hindcasts_symlink_dir | default('../data/hydro/') }}"
  use_symlink_inputs: {{ paths.use_symlink_inputs | default(false) }}  # set true to build per-period symlink dirs from hindcasts_source_dir

# ---------------------------------------------------------------------------
# Flow configurations — one OceanTracker baseline YAML per entry
# (file: params/base/gate_<suffix>.yaml)
# ---------------------------------------------------------------------------
flow_configs:
{%- for fc in flow_configs | default([]) %}
  - name: "{{ fc.name }}"
    suffix: "{{ fc.suffix }}"
{%- else %}
  []  # populate with e.g. {name: 'Baseline', suffix: 'baseline'}
{%- endfor %}

# ---------------------------------------------------------------------------
# Simulation periods — one PTM run per (flow_config x period) combination
# ---------------------------------------------------------------------------
simulation_periods:
{%- for p in simulation_periods | default([]) %}
  - name: {{ p.name }}
    start_date: {{ p.start_date }}
    n_releases: {{ p.n_releases | default(4) }}
    release_spacing_days: {{ p.release_spacing_days | default(7) }}
    start_id: {{ p.start_id }}
    end_id: {{ p.end_id }}
{%- else %}
  []  # populate with start_date, n_releases, start_id, end_id, etc.
{%- endfor %}

# ---------------------------------------------------------------------------
# Polygons — used by setup.py to build releases and statistics
# ---------------------------------------------------------------------------
polygons:
  release_regions:
{%- for rr in polygons.release_regions | default([]) %}
    - name: "{{ rr.name }}"
      release: {{ rr.release | default(true) }}
      release_interval: {{ rr.release_interval | default(3600) }}
      pulse_size: {{ rr.pulse_size | default(1000) }}
      file: "{{ rr.file }}"
{%- else %}
    []  # populate with polygon file references
{%- endfor %}
  destination_regions:
{%- for dr in polygons.destination_regions | default([]) %}
    - name: "{{ dr.name }}"
      file: "{{ dr.file }}"
{%- else %}
    []  # populate with polygon file references
{%- endfor %}

# ---------------------------------------------------------------------------
# OceanTracker run settings — read by setup.py
# ---------------------------------------------------------------------------
run:
  duration: {{ run.duration | default(259200) }}    # seconds; 259200 = 3 days, 5184000 = 60 days
  time_step: {{ run.time_step | default(120) }}      # seconds
  write_tracks: {{ run.write_tracks | default(true) }}
