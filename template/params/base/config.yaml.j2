# =============================================================================
# Baseline OceanTracker run configuration for experiment: {{ name }}
# Generated from: {{ _config_file }}
#
# This file is the starting-point OceanTracker run config.  setup.py reads
# this file (or a per-gate variant named gate_<suffix>.yaml next to it),
# mutates it programmatically (adding releases, statistics, input_dir, etc.),
# and writes the final parameter YAML to params/prod/.
#
# Prod-only overrides can also be placed in params/prod/<scenario>.yaml;
# those are NOT auto-merged — setup.py handles merging explicitly.
# =============================================================================

# ---------------------------------------------------------------------------
# Hydrodynamic reader
# ---------------------------------------------------------------------------
reader:
  class_name: SCHISMreaderV5
  input_dir: "{{ paths.hindcasts_symlink_dir | default('../data/hydro') }}"
  file_mask: "{{ reader.file_mask | default('*.nc') }}"

# ---------------------------------------------------------------------------
# Run settings
# ---------------------------------------------------------------------------
root_output_dir: "{{ user.output_dir | default('../outputs/PTM/') }}"
output_file_base: "{{ name }}"
max_run_duration: {{ run.duration | default(604800) }}   # seconds (default: 7 days)
time_step: {{ run.time_step | default(120) }}    # seconds
write_tracks: {{ run.write_tracks | default(true) }}

# ---------------------------------------------------------------------------
# Release groups — populated programmatically by setup.py
# ---------------------------------------------------------------------------
release_groups: []

# ---------------------------------------------------------------------------
# Particle statistics — populated programmatically by setup.py
# ---------------------------------------------------------------------------
particle_statistics: []

# ---------------------------------------------------------------------------
# Particle properties
# ---------------------------------------------------------------------------
particle_properties: []

# ---------------------------------------------------------------------------
# Event loggers
# ---------------------------------------------------------------------------
event_loggers: []
